{
  "name": "hospital",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/var/www/html",
  "forwardPorts": [8080, 8081],
  "portsAttributes": {
    "8080": {
      "label": "Hospital App",
      "onAutoForward": "openBrowser"
    },
    "8081": {
      "label": "phpMyAdmin",
      "onAutoForward": "notify"
    }
  },
  "postStartCommand": "echo 'Hospital pronto em http://localhost:8080'"
}